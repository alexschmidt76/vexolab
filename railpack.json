{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "lts"
  },
  "steps": {
    "checkLevel": {
      "commands": ["ls"]
    },
    "install": {
      "commands": ["cd server && npm install"]
    },
    "build": {
      "commands": ["cd server && npm run build"]
    }
  },
  "deploy": {
    "startCommand": "node server/dist/server/index.js"
  }
}
