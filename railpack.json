{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "lts"
  },
  "steps": {
    "install": {
      "commands": ["npm install"]
    },
    "build": {
      "commands": ["npm run build"]
    }
  },
  "deploy": {
    "startCommand": "node dist/server/index.js"
  }
}
