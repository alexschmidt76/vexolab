{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "lts"
  },
  "steps": {
    "install": {
      "commands": ["find /app -maxdepth 3 -name 'package.json' 2>/dev/null; ls /app/; npm --prefix server install"]
    },
    "build": {
      "commands": ["npm --prefix server run build"]
    }
  },
  "deploy": {
    "startCommand": "node server/dist/server/index.js"
  }
}
