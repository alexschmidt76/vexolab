{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "lts"
  },
  "steps": {
    "build": {
      "commands": ["npm --prefix server install", "npm --prefix server run build"]
    }
  },
  "deploy": {
    "startCommand": "node server/dist/server/index.js"
  }
}
